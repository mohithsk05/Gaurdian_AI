# GuardianAI Environment Variables

# Google Gemini API Key - Retrieve from Google AI Studio
# Leave empty to run in Fallback/Simulation mode
GEMINI_API_KEY=your_gemini_api_key_here

# JWT Cryptographic Secret (use a secure random string in production)
JWT_SECRET=guardian-super-secret-security-key-2026

# Database Path (default to SQLite local database)
DATABASE_URL=sqlite:///./guardian_ai.db

# MCP Server Execution Command (adjust paths for your environment)
MCP_SERVER_COMMAND=python C:/Users/Sujan/.gemini/antigravity/scratch/guardian-ai/mcp-server/server.py
